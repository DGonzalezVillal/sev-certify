[Unit]
Description=Show the guest logs for the appropriate services in the host
After=systemd-journal-remote.service tests.target
Wants=systemd-journal-remote.service tests.target
Requires=tests.target

[Service]
Type=oneshot
ExecStart=/usr/local/lib/scripts/display-guest-logs.sh
StandardOutput=journal+console
StandardError=journal+console
LogExtraFields="SEV_VERSION=3.0-0" "SNPHOST_TEST=3.0-0"
